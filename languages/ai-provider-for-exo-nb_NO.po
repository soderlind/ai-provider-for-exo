#. Plugin Name of the plugin
#: ai-provider-for-exo.php
msgid "AI Provider for exo"
msgstr "AI-leverandør for exo"

#. Plugin URI of the plugin
#: ai-provider-for-exo.php
msgid "https://github.com/soderlind/ai-provider-for-exo"
msgstr "https://github.com/soderlind/ai-provider-for-exo"

#. Description of the plugin
#: ai-provider-for-exo.php
msgid "Connect WordPress to exo — run frontier AI models locally on your device cluster."
msgstr "Koble WordPress til exo — kjør frontier AI-modeller lokalt på enhetene dine."

#. Author of the plugin
#: ai-provider-for-exo.php
msgid "Per Søderlind"
msgstr "Per Søderlind"

#. Author URI of the plugin
#: ai-provider-for-exo.php
msgid "https://soderlind.no/"
msgstr "https://soderlind.no/"


{
	"name": "soderlind/ai-provider-for-exo",
	"description": "AI Provider for exo — WordPress 7 connector",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.3"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6"
	},
	"autoload": {
		"psr-4": {
			"Exo\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Exo\\Tests\\": "tests/php/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-text"
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true
	}
}
